{
  "info": {
    "_postman_id": "Kudistocks",
    "name": "Kudistocks API",
    "description": "Complete API collection for InventoryPro - Production-grade Inventory Management System\n\n## Setup\n1. Set base_url to http://localhost:3030/api\n2. Register and get token\n3. Set token variable in environment\n4. Create a store and set store_id variable\n\n## Variables\n- base_url: http://localhost:8080/api\n- token: (set after login)\n- store_id: (set after creating store)\n- product_id: (set after creating product)\n- order_id: (set after creating order)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3030/api" },
    { "key": "token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "store_id", "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "supplier_id", "value": "" },
    { "key": "notification_id", "value": "" }
  ],
  "item": [
    {
      "name": "🔒 Auth",
      "item": [
        {
          "name": "Register with Email",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { var res = pm.response.json(); pm.collectionVariables.set('token', res.data.token); pm.collectionVariables.set('refresh_token', res.data.refreshToken); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\",\n  \"language\": \"en\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register with Phone",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { var res = pm.response.json(); pm.collectionVariables.set('token', res.data.token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"phoneNumber\": \"08012345678\",\n  \"countryCode\": \"+234\",\n  \"password\": \"password123\",\n  \"language\": \"en\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { var res = pm.response.json(); pm.collectionVariables.set('token', res.data.token); pm.collectionVariables.set('refresh_token', res.data.refreshToken); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Verify OTP (Email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"otp\": \"123456\",\n  \"type\": \"email\"\n}" },
            "url": { "raw": "{{base_url}}/auth/verify-otp", "host": ["{{base_url}}"], "path": ["auth", "verify-otp"] }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"email\"\n}" },
            "url": { "raw": "{{base_url}}/auth/resend-otp", "host": ["{{base_url}}"], "path": ["auth", "resend-otp"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john.doe@example.com\"\n}" },
            "url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"YOUR_RESET_TOKEN\",\n  \"newPassword\": \"newpassword123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/reset-password", "host": ["{{base_url}}"], "path": ["auth", "reset-password"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { var res = pm.response.json(); pm.collectionVariables.set('token', res.data.token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/refresh-token", "host": ["{{base_url}}"], "path": ["auth", "refresh-token"] }
          }
        },
