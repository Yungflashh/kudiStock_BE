              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe Updated\",\n  \"language\": \"fr\",\n  \"notificationSettings\": {\n    \"emailNotifications\": true,\n    \"smsNotifications\": false,\n    \"lowStockAlerts\": true,\n    \"orderUpdates\": true\n  }\n}"
